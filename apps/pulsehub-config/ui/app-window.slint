import { Button } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { OverviewPage } from "pages/overview-page.slint";
import { ProfilePage } from "pages/profile-page.slint";
import { SettingsPage } from "pages/settings-page.slint";
import { MappingItem } from "models.slint";

export component AppWindow inherits Window {
    title: "PulseHub";
    preferred-width: 960px; preferred-height: 680px; min-width: 800px; min-height: 600px;
    background: Theme.canvas;
    in-out property <int> selected-page: 0;
    in-out property <bool> draft-dirty: false;
    in-out property <bool> busy: false;
    in-out property <bool> close-dialog-visible: false;
    in-out property <bool> close-after-save: false;
    in-out property <bool> mapping-editor-visible: false;
    in-out property <bool> mapping-editor-office: true;
    in-out property <int> mapping-editor-index: -1;
    in-out property <string> mapping-editor-label: "";
    in-out property <string> captured-key: "";
    in-out property <string> captured-preview: "尚未输入";
    in-out property <bool> captured-control: false;
    in-out property <bool> captured-shift: false;
    in-out property <bool> captured-alt: false;
    in-out property <bool> captured-meta: false;
    in-out property <int> office-dpi: 3200;
    in-out property <int> cs2-dpi: 100;
    in-out property <int> office-dpi-level-1: 800;
    in-out property <int> office-dpi-level-2: 1600;
    in-out property <int> office-dpi-level-3: 2400;
    in-out property <int> office-dpi-level-4: 3200;
    in-out property <int> cs2-dpi-level-1: 800;
    in-out property <int> cs2-dpi-level-2: 1600;
    in-out property <int> cs2-dpi-level-3: 2400;
    in-out property <int> cs2-dpi-level-4: 3200;
    in-out property <bool> office-dpi-cycle-enabled: false;
    in-out property <bool> cs2-dpi-cycle-enabled: false;
    in property <[int]> dpi-options;
    in property <int> dpi-minimum: 1;
    in property <int> dpi-maximum: 65535;
    in property <int> dpi-step: 1;
    in property <[MappingItem]> office-mappings;
    in property <[MappingItem]> cs2-mappings;
    in-out property <string> selection-mode: "自动";
    in-out property <bool> start-with-windows: true;
    in property <string> integration-status: "未知";
    in property <string> connection-text: "正在连接代理";
    in property <string> device-status: "正在连接设备";
    in property <string> environment-name: "—";
    in property <string> current-dpi: "—";
    in property <string> desired-dpi: "—";
    in property <string> revision: "—";
    in-out property <int> base-revision: 0;
    in property <string> save-title: "正在读取配置";
    in property <string> save-detail: "连接代理后将显示保存和应用状态。";
    callback refresh-requested();
    callback save-requested(int, int, int, string, bool);
    callback discard-requested();
    callback mapping-restore-requested(bool, int);
    callback mapping-key-requested(bool, int, string, bool, bool, bool, bool);
    callback custom-dpi-requested(bool, string);
    callback dpi-level-requested(bool, int, string);
    callback discard-and-close-requested();
    callback retry-apply-requested();

    VerticalLayout {
        spacing: 0px;
        Rectangle {
            height: 58px; background: Theme.surface; border-color: Theme.hairline; border-width: 1px;
            HorizontalLayout { padding-left: 24px; padding-right: 24px; spacing: 16px;
                Text { text: "PulseHub"; color: Theme.ink; font-size: 20px; font-weight: 600; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; background: transparent; }
                Text { text: root.connection-text; color: Theme.body; font-size: 12px; vertical-alignment: center; }
                Button { text: "刷新"; enabled: !root.busy; clicked => { root.refresh-requested(); } }
            }
        }
        HorizontalLayout {
            spacing: 0px;
            Rectangle {
                width: 184px; background: Theme.surface-soft;
                VerticalLayout { padding: 16px; spacing: 8px;
                    for item[index] in ["设备概览", "Office 配置", "CS2 配置", "设置"]: Rectangle {
                        height: 44px; border-radius: 8px; background: root.selected-page == index ? Theme.primary-soft : transparent;
                        Text { text: item; color: root.selected-page == index ? Theme.primary : Theme.body; font-size: 14px; vertical-alignment: center; x: 12px; }
                        TouchArea { clicked => { root.selected-page = index; } }
                    }
                    Rectangle { vertical-stretch: 1; background: transparent; }
                }
            }
            Rectangle {
                horizontal-stretch: 1; background: Theme.canvas;
                if root.selected-page == 0: OverviewPage { x: 24px; y: 24px; width: parent.width - 48px; height: parent.height - 48px; device-status: root.device-status; environment-name: root.environment-name; current-dpi: root.current-dpi; desired-dpi: root.desired-dpi; apply-title: root.save-title; apply-detail: root.save-detail; apply-enabled: !root.busy && !root.draft-dirty; retry-apply-requested => { root.retry-apply-requested(); } }
                if root.selected-page == 1: ProfilePage { x: 24px; y: 24px; width: parent.width - 48px; height: parent.height - 48px; profile-name: "Office"; dpi: root.office-dpi; dpi-options: root.dpi-options; mappings: root.office-mappings; dpi-cycle-enabled: root.office-dpi-cycle-enabled; dpi-level-1: root.office-dpi-level-1; dpi-level-2: root.office-dpi-level-2; dpi-level-3: root.office-dpi-level-3; dpi-level-4: root.office-dpi-level-4; process-rule: ""; editing-enabled: !root.busy; dpi-changed(value) => { root.office-dpi = value; root.draft-dirty = true; } custom-dpi-submitted(value) => { root.custom-dpi-requested(true, value); } dpi-level-submitted(index, value) => { root.dpi-level-requested(true, index, value); } mapping-input-requested(index) => { root.open-mapping-capture(true, index); } mapping-restore-requested(index) => { root.mapping-restore-requested(true, index); } }
                if root.selected-page == 2: ProfilePage { x: 24px; y: 24px; width: parent.width - 48px; height: parent.height - 48px; profile-name: "CS2"; dpi: root.cs2-dpi; dpi-options: root.dpi-options; mappings: root.cs2-mappings; dpi-cycle-enabled: root.cs2-dpi-cycle-enabled; dpi-level-1: root.cs2-dpi-level-1; dpi-level-2: root.cs2-dpi-level-2; dpi-level-3: root.cs2-dpi-level-3; dpi-level-4: root.cs2-dpi-level-4; process-rule: "cs2.exe"; editing-enabled: !root.busy; dpi-changed(value) => { root.cs2-dpi = value; root.draft-dirty = true; } custom-dpi-submitted(value) => { root.custom-dpi-requested(false, value); } dpi-level-submitted(index, value) => { root.dpi-level-requested(false, index, value); } mapping-input-requested(index) => { root.open-mapping-capture(false, index); } mapping-restore-requested(index) => { root.mapping-restore-requested(false, index); } }
                if root.selected-page == 3: SettingsPage { x: 24px; y: 24px; width: parent.width - 48px; height: parent.height - 48px; revision: root.revision; selection-mode: root.selection-mode; start-with-windows: root.start-with-windows; integration-status: root.integration-status; editing-enabled: !root.busy; selection-mode-cycle => { root.selection-mode = root.selection-mode == "自动" ? "固定 Office" : root.selection-mode == "固定 Office" ? "固定 CS2" : "自动"; root.draft-dirty = true; } start-with-windows-toggle => { root.start-with-windows = !root.start-with-windows; root.draft-dirty = true; } }
            }
        }
        if root.draft-dirty: Rectangle {
            height: 72px; background: Theme.surface; border-color: Theme.hairline; border-width: 1px;
            HorizontalLayout { padding-left: 24px; padding-right: 24px; spacing: 12px;
                VerticalLayout { Text { text: "有未保存的更改"; color: Theme.ink; font-size: 14px; font-weight: 600; } Text { text: "保存后才会发送给代理；应用状态将单独更新。"; color: Theme.muted; font-size: 12px; } }
                Rectangle { horizontal-stretch: 1; background: transparent; }
                Button { text: "放弃更改"; enabled: !root.busy; clicked => { root.discard-requested(); } }
                Button { text: root.busy ? "正在保存" : "保存配置"; primary: true; enabled: !root.busy; clicked => { root.save-requested(root.office-dpi, root.cs2-dpi, root.base-revision, root.selection-mode, root.start-with-windows); } }
            }
        }
    }
    function open-mapping-capture(office: bool, index: int) {
        root.mapping-editor-office = office;
        root.mapping-editor-index = index;
        root.mapping-editor-label = office ? root.office-mappings[index].label : root.cs2-mappings[index].label;
        root.captured-key = "";
        root.captured-preview = "尚未输入";
        root.mapping-editor-visible = true;
    }
    if root.mapping-editor-visible: Rectangle {
        x: 0px; y: 0px; width: parent.width; height: parent.height; background: Theme.overlay;
        Rectangle {
            width: 500px; height: 300px;
            x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
            background: Theme.surface; border-color: Theme.hairline; border-width: 1px; border-radius: 12px;
            VerticalLayout { padding: 24px; spacing: 16px;
                Text { text: "更改 " + root.mapping-editor-label; color: Theme.ink; font-size: 18px; font-weight: 600; }
                VerticalLayout {
                    spacing: 12px;
                    Text { text: "请按一个按键或组合键，然后按 Enter 保存"; color: Theme.body; font-size: 14px; }
                    Rectangle {
                        height: 64px; border-color: Theme.primary; border-width: 2px; border-radius: 8px; background: Theme.primary-soft;
                        Text { text: root.captured-preview; color: Theme.ink; font-size: 18px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                        capture-focus := FocusScope {
                            init => { self.focus(); }
                            key-pressed(event) => {
                                if (event.text == Key.Escape) { root.mapping-editor-visible = false; return accept; }
                                if (event.text == Key.Return) {
                                    if (root.captured-key != "") {
                                        root.mapping-key-requested(root.mapping-editor-office, root.mapping-editor-index, root.captured-key, root.captured-control, root.captured-shift, root.captured-alt, root.captured-meta);
                                        root.mapping-editor-visible = false;
                                    }
                                    return accept;
                                }
                                if (event.text == Key.Control || event.text == Key.Shift || event.text == Key.Alt || event.text == Key.Meta) { return accept; }
                                root.captured-key = event.text == Key.Backspace ? "Backspace" : event.text == Key.Delete ? "Delete" : event.text == Key.Tab ? "Tab" : event.text == Key.Space ? "Space" : event.text == Key.LeftArrow ? "Left" : event.text == Key.RightArrow ? "Right" : event.text == Key.UpArrow ? "Up" : event.text == Key.DownArrow ? "Down" : event.text;
                                root.captured-control = event.modifiers.control;
                                root.captured-shift = event.modifiers.shift;
                                root.captured-alt = event.modifiers.alt;
                                root.captured-meta = event.modifiers.meta;
                                root.captured-preview = (root.captured-control ? "Ctrl + " : "") + (root.captured-shift ? "Shift + " : "") + (root.captured-alt ? "Alt + " : "") + (root.captured-meta ? "Win + " : "") + root.captured-key;
                                accept
                            }
                        }
                    }
                    Text { text: "Esc 取消；每个映射支持修饰键加一个主键。"; color: Theme.muted; font-size: 12px; }
                }
                Rectangle { vertical-stretch: 1; background: transparent; }
                Button { text: "取消"; clicked => { root.mapping-editor-visible = false; } }
            }
        }
    }
    if root.close-dialog-visible: Rectangle {
        x: 0px; y: 0px; width: parent.width; height: parent.height;
        background: Theme.overlay;
        Rectangle {
            width: 460px; height: 230px; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
            background: Theme.surface; border-color: Theme.hairline; border-width: 1px; border-radius: 12px;
            VerticalLayout { padding: 24px; spacing: 16px;
                Text { text: "保存更改后关闭？"; color: Theme.ink; font-size: 18px; font-weight: 600; }
                Text { text: "Office 和 CS2 共用一个待提交草稿。关闭前可以保存，也可以明确放弃本次更改。"; color: Theme.body; font-size: 14px; wrap: word-wrap; }
                Rectangle { vertical-stretch: 1; background: transparent; }
                HorizontalLayout { spacing: 10px;
                    Button { text: "取消"; clicked => { root.close-dialog-visible = false; } }
                    Rectangle { horizontal-stretch: 1; background: transparent; }
                    Button { text: "放弃更改"; clicked => { root.close-dialog-visible = false; root.discard-and-close-requested(); } }
                    Button { text: "保存并关闭"; primary: true; enabled: !root.busy; clicked => { root.close-dialog-visible = false; root.close-after-save = true; root.save-requested(root.office-dpi, root.cs2-dpi, root.base-revision, root.selection-mode, root.start-with-windows); } }
                }
            }
        }
    }
}
