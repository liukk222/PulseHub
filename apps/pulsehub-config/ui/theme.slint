export global Theme {
    in property <color> canvas: #faf9f5;
    in property <color> surface: #ffffff;
    in property <color> surface-soft: #f5f0e8;
    in property <color> ink: #1d1c1a;
    in property <color> body: #45433f;
    in property <color> muted: #706d66;
    in property <color> hairline: #ded8cf;
    in property <color> primary: #c96f52;
    in property <color> primary-soft: #f4e3dc;
    in property <color> success: #3f8f57;
    in property <color> success-soft: #e7f3ea;
    in property <color> warning: #a66f00;
    in property <color> warning-soft: #fff3d6;
    in property <color> error: #b83e3e;
    in property <color> error-soft: #fbe8e8;
}
